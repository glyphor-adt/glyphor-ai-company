FROM node:22-slim AS builder

WORKDIR /app

COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY packages/mcp-sharepoint-sites/package.json ./packages/mcp-sharepoint-sites/package.json

RUN npm ci

COPY packages/mcp-sharepoint-sites/ packages/mcp-sharepoint-sites/

RUN npx turbo build --filter=@glyphor/mcp-sharepoint-sites

FROM node:22-slim AS runtime

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/mcp-sharepoint-sites/package.json ./packages/mcp-sharepoint-sites/package.json

RUN npm ci --omit=dev

COPY --from=builder /app/packages/mcp-sharepoint-sites/dist packages/mcp-sharepoint-sites/dist

ENV NODE_ENV=production
EXPOSE 8080

CMD ["node", "packages/mcp-sharepoint-sites/dist/index.js"]
