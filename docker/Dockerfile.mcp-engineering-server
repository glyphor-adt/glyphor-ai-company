# ─── Stage 1: Build ───────────────────────────────────────────
FROM node:22-slim AS builder

WORKDIR /app

COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY packages/mcp-engineering-server/package.json ./packages/mcp-engineering-server/package.json

RUN npm ci

COPY packages/mcp-engineering-server/ packages/mcp-engineering-server/

RUN npx turbo build --filter=@glyphor/mcp-engineering-server

# ─── Stage 2: Runtime ────────────────────────────────────────
FROM node:22-slim AS runtime

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/mcp-engineering-server/package.json ./packages/mcp-engineering-server/package.json

RUN npm ci --omit=dev

COPY --from=builder /app/packages/mcp-engineering-server/dist packages/mcp-engineering-server/dist

ENV NODE_ENV=production
EXPOSE 8080

CMD ["node", "packages/mcp-engineering-server/dist/index.js"]
