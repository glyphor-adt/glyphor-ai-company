{
  "name": "glyphor-company",
  "private": true,
  "version": "0.1.0",
  "description": "Glyphor AI Company — Autonomous executive team running Fuse and Pulse",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "seed": "bash infra/scripts/seed-memory.sh",
    "cos:briefing": "tsx packages/agents/src/chief-of-staff/run.ts briefing",
    "cos:run": "tsx packages/agents/src/chief-of-staff/run.ts",
    "dashboard": "powershell -File infra/scripts/open-dashboard.ps1",
    "dashboard:dev": "npm run dev --workspace=packages/dashboard",
    "scheduler:dev": "turbo run build --filter=@glyphor/scheduler && node --env-file=.env packages/scheduler/dist/server.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.8.3",
    "tsx": "^4.19.0",
    "@types/node": "^22.15.0"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
