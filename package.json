{
  "name": "glyphor-company",
  "private": true,
  "version": "0.1.0",
  "description": "Glyphor AI Company — Autonomous executive team running Web Build and Pulse",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:local": "powershell -ExecutionPolicy Bypass -File scripts/run-with-local-db-proxy.ps1",
    "db:local:system": "powershell -ExecutionPolicy Bypass -File scripts/run-with-local-db-proxy.ps1 -DbRole system",
    "db:local:query": "powershell -ExecutionPolicy Bypass -File scripts/run-with-local-db-proxy.ps1 -Run node _run_queries.js",
    "db:drift-check": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/check-schema-drift.ts",
    "db:activate-founder-directives": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/activate-founder-directives.ts",
    "db:seed-pulse-mcp-knowledge": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/seed-pulse-mcp-knowledge.ts",
    "db:reconcile-ledger": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/reconcile-migration-ledger.ts",
    "db:apply-migration": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/apply-migration.ts",
    "db:apply-pending": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/apply-pending-migrations.ts",
    "db:pool-activity": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/db-pool-activity.ts",
    "db:usage-queries": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/diagnostic-usage-queries.ts",
    "db:stale-assignments": "tsx scripts/query-stale-assignments.ts",
    "db:stale-assignments:gcp": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/query-stale-assignments.ts",
    "db:cancel-stale-assignments": "tsx scripts/cancel-stale-assignments.ts",
    "db:cancel-stale-assignments:gcp": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_app --db-password-secret db-password scripts/cancel-stale-assignments.ts",
    "skills:it:generate-migration": "tsx scripts/generate-it-skill-migration.ts",
    "skills:test": "tsx scripts/test-skills.ts",
    "skills:canary-report": "tsx scripts/skill-canary-report.ts",
    "web-template:bootstrap": "tsx scripts/bootstrap-web-template-react.ts",
    "directives:web-creation:dispatch": "tsx scripts/run-with-gcp-db-secret.ts --db-user glyphor_system_user --db-password-secret db-system-password scripts/dispatch-web-creation-implementation-directive.ts",
    "decisions:cleanup-orphaned": "tsx scripts/cleanup-orphaned-decisions.ts",
    "seed": "bash infra/scripts/seed-memory.sh",
    "cos:briefing": "tsx packages/agents/src/chief-of-staff/run.ts briefing",
    "cos:run": "tsx packages/agents/src/chief-of-staff/run.ts",
    "dashboard": "powershell -File infra/scripts/open-dashboard.ps1",
    "dashboard:dev": "npm run dev --workspace=packages/dashboard",
    "scheduler:dev": "turbo run build --filter=@glyphor/scheduler && node --env-file=.env packages/scheduler/dist/server.js",
    "smoketest": "turbo run build --filter=@glyphor/smoketest && node --env-file=.env packages/smoketest/dist/index.js",
    "validate:pricing": "tsx scripts/validate-model-pricing.ts",
    "validate:doctrine": "tsx scripts/validate-doctrine-consistency.ts",
    "validate:agent365": "tsx scripts/validate-agent365-setup.ts",
    "validate:agent365:strict": "tsx scripts/validate-agent365-setup.ts --strict-env",
    "validate:website-pipeline:cloudrun": "tsx scripts/verify-website-pipeline-cloudrun-env.ts",
    "preview-worker:dev": "npx wrangler dev --config workers/preview/wrangler.toml",
    "preview-worker:deploy": "npx wrangler deploy --config workers/preview/wrangler.toml",
    "preview-worker:typecheck": "npx tsc -p workers/preview/tsconfig.json --noEmit",
    "ops:autonomy:slo": "tsx scripts/check-agent-autonomy-slo.ts",
    "trace:summary": "tsx scripts/trace-span-summary.ts",
    "trace:summary:cloudrun": "tsx scripts/trace-span-cloudrun-summary.ts",
    "run:replay": "tsx scripts/run-replay.ts",
    "db:agent-schedules-subset": "tsx scripts/query-agent-schedules-subset.ts",
    "smoke:all-agents": "tsx scripts/smoke-test-all-agents.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "dotenv": "^17.3.1",
    "pg": "^8.16.3",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
