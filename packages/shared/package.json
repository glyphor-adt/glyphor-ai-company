{
  "name": "@glyphor/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./middleware/auth": {
      "types": "./dist/middleware/auth.d.ts",
      "default": "./dist/middleware/auth.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "default": "./dist/models.js"
    },
    "./governance": {
      "types": "./dist/governance.d.ts",
      "default": "./dist/governance.js"
    },
    "./canonicalKeepRoster": {
      "types": "./dist/canonicalKeepRoster.d.ts",
      "default": "./dist/canonicalKeepRoster.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "firebase-admin": "^12.0.0",
    "@google-cloud/storage": "^7.19.0",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
