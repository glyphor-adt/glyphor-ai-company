{
  "name": "@glyphor/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared/*": {
      "types": "./dist/shared/*.d.ts",
      "default": "./dist/shared/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "@glyphor/agent-runtime": "*",
    "@glyphor/company-memory": "*",
    "@glyphor/integrations": "*",
    "@glyphor/shared": "*",
    "e2b": "^2.18.0",
    "openai": "^4.78.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "stripe": "^17.5.0",
    "typescript": "^5.8.3"
  }
}
