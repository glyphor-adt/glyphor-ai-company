# Amazon Bedrock — Claude + DeepSeek in agent-runtime (@aws-sdk/client-bedrock-runtime)

#

# Claude on Bedrock does NOT use an Anthropic API key (sk-ant-...). Access is through AWS IAM.

#

# Recommended for servers and local dev without browser SSO: IAM user access keys + Bedrock policy

# (e.g. AmazonBedrockLimitedAccess), set below. The AWS SDK picks these up automatically.

#

# Alternative: `aws login` / `aws sso login` only — then omit the keys and optionally set

# AWS_PROFILE=your-profile

#

# You still need models enabled in Bedrock for your account/region, and IAM allowing

# bedrock:InvokeModel on those models or inference profiles.

#

AWS_REGION=us-east-1

BEDROCK_ENABLED=true

# IAM programmatic access (typical for Glyphor + Bedrock):

# AWS_ACCESS_KEY_ID=

# AWS_SECRET_ACCESS_KEY=


